QQ_BOT_APP_ID=your_app_id
QQ_BOT_SECRET=your_app_secret

# Optional: true uses sandbox API host
QQ_BOT_SANDBOX=false
QQ_BOT_INTENTS=PUBLIC_GUILD_MESSAGES,GROUP_AND_C2C
QQ_BOT_API_BASE=
QQ_BOT_TOKEN_BASE=

# Optional: override codex executable path
CODEX_BIN=
CODEX_HOME=
RUNNER_CODEX_HOME=

# Optional: default workspace and extra writable directories.
# RUNNER_WORKDIR is used on first start or when no runner state file exists.
RUNNER_WORKDIR=
RUNNER_ADD_DIRS=

# Optional: read / write / safe / full
CODEX_ACCESS_MODE=safe

# Optional: max idle time without new Codex output (milliseconds). Set 0 to disable.
CODEX_EXEC_TIMEOUT_MS=1800000

# Optional: enable Weixin long-poll channel (text only for now).
# Once a Weixin account is authorized, the running runner can hot-load it without restart.
WEIXIN_ENABLED=true
WEIXIN_ACCOUNT_ID=default
WEIXIN_BASE_URL=
WEIXIN_TOKEN=
WEIXIN_LONG_POLL_TIMEOUT_MS=35000
WEIXIN_BOT_TYPE=3
