# QQ 机器人配置（JSON 数组，必填）。
# 每一项必须包含 appId 和 secret。可选字段：
#   id      - session 隔离键；省略则用 appId。多机器人时不同 id 的会话互不影响。
#   name    - 展示别称（/status 和日志里可见）；省略则用 id。
#   intents - 逗号分隔，省略继承全局 QQ_BOT_INTENTS
#   apiBase / tokenBase / sandbox - 省略继承全局默认
QQ_BOTS=[{"id":"main","name":"主号","appId":"111","secret":"aaa"},{"id":"test","name":"测试号","appId":"222","secret":"bbb"}]

# Optional: true uses sandbox API host
QQ_BOT_SANDBOX=false
QQ_BOT_INTENTS=PUBLIC_GUILD_MESSAGES,GROUP_AND_C2C
QQ_BOT_API_BASE=
QQ_BOT_TOKEN_BASE=

# Optional: override codex executable path
CODEX_BIN=
CODEX_HOME=
RUNNER_CODEX_HOME=

# Optional: override claude executable path (Claude Code CLI).
CLAUDE_BIN=
# Optional: dedicated CLAUDE_CONFIG_DIR for the runner (analog to RUNNER_CODEX_HOME).
# When set, the runner passes CLAUDE_CONFIG_DIR=<this> to the claude subprocess.
RUNNER_CLAUDE_HOME=

# Optional: default backend for new conversations when /backend hasn't been set for a scope.
# Values: codex | claude. Defaults to claude.
RUNNER_DEFAULT_BACKEND=

# Optional: default workspace and extra writable directories.
# RUNNER_WORKDIR is used on first start or when no runner state file exists.
RUNNER_WORKDIR=
RUNNER_ADD_DIRS=

# Optional: read / write / safe / full
CODEX_ACCESS_MODE=safe

# Optional: max idle time without new Codex output (milliseconds). Set 0 to disable.
CODEX_EXEC_TIMEOUT_MS=1800000

# Optional: global concurrent run cap across all sessions (default 3).
# Each (scope + workdir + backend) has its own queue; up to this many run concurrently.
RUNNER_MAX_CONCURRENCY=3

# Optional: override Codex context management for runner sessions.
# If your Codex config uses a very high auto compact threshold (for example 900000 with a 1000000 window),
# the runner may appear to never compact. Set a lower limit here if needed.
CODEX_CONTEXT_WINDOW=
CODEX_AUTO_COMPACT_TOKEN_LIMIT=

# Optional: enable Weixin long-poll channel (text only for now).
# Once a Weixin account is authorized, the running runner can hot-load it without restart.
# All accounts stored in logs/runner-state.json via --weixin-login start automatically.
# Set WEIXIN_ACCOUNTS to a comma-separated whitelist to only start a subset.
# Account aliases: persist via `--weixin-login --weixin-name <alias>`, or set WEIXIN_NAMES
# JSON for bulk overrides. Default alias: "微信机器人" for the "default" account, accountId otherwise.
WEIXIN_ENABLED=true
WEIXIN_ACCOUNT_ID=default
WEIXIN_ACCOUNTS=
# WEIXIN_NAMES={"default":"微信机器人","work":"工作号"}
WEIXIN_NAMES=
WEIXIN_BASE_URL=
WEIXIN_TOKEN=
WEIXIN_LONG_POLL_TIMEOUT_MS=35000
WEIXIN_BOT_TYPE=3
